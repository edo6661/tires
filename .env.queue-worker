# 🗄️ Database - CRITICAL: Must match web service
DB_CONNECTION=pgsql
DB_DATABASE=railway
DB_HOST=postgres-a1yd.railway.internal
DB_PASSWORD=DvvJcYHhEulFutMesujhhcKFXNueHZpO
DB_PORT=5432
DB_SSLMODE=require
