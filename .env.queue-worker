MAIL_HOST=smtp.gmail.com
MAIL_MAILER=smtp
MAIL_PASSWORD=gbls pamd bhyo syyu
MAIL_PORT=587
MAIL_USERNAME=sifactory16@gmail.com

# Memory Cache
MEMCACHED_HOST=127.0.0.1

# PHP Workers
PHP_CLI_SERVER_WORKERS=4

# 🔴 QUEUE CONFIGURATION - MOST IMPORTANT
QUEUE_CONNECTION=redis

# 🔴 REDIS CONFIGURATION - MUST MATCH WEB SERVICE EXACTLY
REDIS_CLIENT=predis
REDIS_HOST=shortline.proxy.rlwy.net
REDIS_PASSWORD=dEVvfZXxWxwtLvnNAyWyRVtNxCAQFRRa
REDIS_PORT=43828
REDIS_URL=redis://default:dEVvfZXxWxwtLvnNAyWyRVtNxCAQFRRa@shortline.proxy.rlwy.net:43828

# Session Configuration
SESSION_DOMAIN=null
SESSION_DRIVER=database
SESSION_ENCRYPT=false
SESSION_LIFETIME=120
SESSION_PATH=/

# Vite
VITE_APP_NAME="${APP_NAME}"

# ============================================================================
# DEPLOYMENT INSTRUCTIONS
# ============================================================================
#
# 1. Go to Railway Dashboard
# 2. Click "New" → "Empty Service" → Name it "tires-queue-worker"
# 3. Connect to GitHub repository (same as web service)
# 4. Go to Settings → Environment → Add all variables above
# 5. Go to Settings → Deploy → Start Command:
#
#    php artisan queue:work redis --tries=3 --timeout=90 --sleep=3 --max-jobs=1000
#
# 6. Deploy the service
# 7. Check logs to verify worker is running
#
# ============================================================================
# MONITORING
# ============================================================================
#
# Check if worker is processing jobs:
# railway logs -s tires-queue-worker
#
# You should see:
# [2025-12-04 12:00:00] Processing: App\Mail\BookingConfirmationMail
# [2025-12-04 12:00:01] Processed: App\Mail\BookingConfirmationMail
#
# ============================================================================
