# ============================================================================
# RAILWAY QUEUE WORKER SERVICE - ENVIRONMENT VARIABLES
# ============================================================================
# Service Name: tires-queue-worker
# Start Command: php artisan queue:work redis --tries=3 --timeout=90 --sleep=3 --max-jobs=1000
# ============================================================================

# Application Configuration
APP_DEBUG=false
APP_ENV=production
APP_FAKER_LOCALE=en_US
APP_FALLBACK_LOCALE=en
